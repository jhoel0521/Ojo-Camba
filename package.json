{
  "name": "ojo-camba",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"./backend/**\" --filter \"./frontend/**\" dev",
    "dev:backend": "pnpm -r --parallel --filter \"./backend/**\" dev",
    "dev:frontend": "pnpm -r --parallel --filter \"./frontend/**\" dev",
    "build": "pnpm build:backend && pnpm build:frontend",
    "build:libs": "pnpm -r --filter \"./libs/**\" build",
    "build:backend": "pnpm run build:libs && pnpm -r --filter \"./backend/**\" build",
    "build:frontend": "pnpm -r --filter \"./frontend/**\" build",
    "health": "node scripts/ping.mjs",
    "dev:check": "node scripts/dev-check.mjs",
    "docker:up": "docker compose -f docker/dev/docker-compose.infra.yml up -d",
    "docker:down": "docker compose -f docker/dev/docker-compose.infra.yml down",
    "docker:dev": "docker compose -f docker/dev/docker-compose.yml up",
    "docker:dev:build": "docker compose -f docker/dev/docker-compose.yml up --build",
    "lint:backend": "eslint \"backend/**/*.ts\" \"libs/**/*.ts\" --ext .ts",
    "lint:frontend": "pnpm -r --filter \"./frontend/**\" lint",
    "lint": "pnpm run lint:backend && pnpm run lint:frontend",
    "format": "prettier --write \"backend/**/*.ts\" \"libs/**/*.ts\" \"frontend/**/*.tsx\" \"frontend/**/*.ts\"",
    "db:fresh": "node scripts/db-fresh-seed.mjs",
    "db:migrate": "pnpm --filter @ojo-camba/ms-register sync",
    "db:fresh:seed": "pnpm db:fresh && pnpm db:migrate && pnpm db:seed",
    "db:seed": "pnpm --filter @ojo-camba/ms-register seed",
    "pre-commit": "pnpm run format && pnpm run lint && pnpm run build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.8.4"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": ">=3.1.2",
      "file-type": ">=21.3.2",
      "lodash": ">=4.18.0",
      "uuid": ">=11.1.1",
      "@fastify/middie": ">=9.3.2",
      "glob": ">=10.5.0",
      "esbuild@<=0.24.2": ">=0.25.0",
      "tmp@<=0.2.3": ">=0.2.4",
      "@nestjs/platform-fastify@<11.1.10": ">=11.1.11",
      "fastify@<=5.7.2": ">=5.7.3",
      "fastify@<5.7.2": ">=5.7.2",
      "webpack@>=5.49.0 <=5.104.0": ">=5.104.1",
      "webpack@>=5.49.0 <5.104.0": ">=5.104.0",
      "@nestjs/platform-fastify@<=11.1.13": ">=11.1.14",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "@nestjs/platform-fastify@<=11.1.15": ">=11.1.16",
      "fastify@<=5.8.2": ">=5.8.3",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "vite@<=6.4.1": ">=6.4.2",
      "@nestjs/core@<=11.1.17": ">=11.1.18",
      "@nestjs/microservices@<=11.1.18": ">=11.1.19",
      "tmp@<0.2.6": ">=0.2.6",
      "vite@<=6.4.2": ">=6.4.3",
      "@nestjs/platform-fastify@<=11.1.23": ">=11.1.24"
    }
  }
}
