{
  "name": "ojo-camba",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "pnpm dev:backend",
    "dev:backend": "pnpm -r --filter \"./backend/**\" dev",
    "dev:frontend": "pnpm -r --filter \"./frontend/**\" dev",
    "build": "pnpm build:backend && pnpm build:frontend",
    "build:backend": "pnpm -r --filter \"./backend/**\" build",
    "build:frontend": "pnpm -r --filter \"./frontend/**\" build",
    "ping": "node scripts/ping.mjs",
    "docker:up": "docker compose -f docker/dev/docker-compose.infra.yml up -d",
    "docker:down": "docker compose -f docker/dev/docker-compose.infra.yml down",
    "docker:dev": "docker compose -f docker/dev/docker-compose.yml up",
    "docker:dev:build": "docker compose -f docker/dev/docker-compose.yml up --build",
    "lint:backend": "eslint \"backend/**/*.ts\" \"libs/**/*.ts\" --ext .ts",
    "lint:frontend": "pnpm -r --filter \"./frontend/**\" lint",
    "lint": "pnpm run lint:backend && pnpm run lint:frontend",
    "format": "prettier --write \"backend/**/*.ts\" \"libs/**/*.ts\" \"frontend/**/*.tsx\" \"frontend/**/*.ts\"",
    "pre-commit": "pnpm run format && pnpm run lint && pnpm run build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.0"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  }
}
