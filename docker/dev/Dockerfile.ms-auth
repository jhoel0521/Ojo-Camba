FROM node:22-alpine

WORKDIR /app

RUN npm install -g pnpm@9

# Manifests separados para aprovechar caché de capas
COPY pnpm-workspace.yaml package.json .npmrc ./
COPY libs/common/package.json libs/common/
COPY backend/ms-auth/package.json backend/ms-auth/

RUN pnpm install

COPY tsconfig.base.json ./

# El código fuente se monta como volumen en dev (ver docker-compose.yml)

WORKDIR /app/backend/ms-auth

CMD ["pnpm", "dev"]
