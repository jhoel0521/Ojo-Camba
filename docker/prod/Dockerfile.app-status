# ── Stage 1: Build Vite ─────────────────────────────────────
FROM node:22-alpine AS builder

WORKDIR /app

RUN npm install -g pnpm@9

COPY pnpm-workspace.yaml package.json .npmrc ./
COPY frontend/app-status/package.json frontend/app-status/

RUN pnpm install --frozen-lockfile

COPY frontend/app-status/ frontend/app-status/

WORKDIR /app/frontend/app-status

ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL

RUN pnpm build

# ── Stage 2: Nginx ───────────────────────────────────────────
FROM nginx:alpine AS runner

COPY --from=builder /app/frontend/app-status/dist /usr/share/nginx/html
COPY docker/prod/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
